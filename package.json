{
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "playwright-bdd": "^9.2.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "vite": "^8.0.16"
  },
  "scripts": {
    "dev": "vite",
    "at": "bddgen && playwright test",
    "build": "tsc -p ./tsconfig.json",
    "start:dev": "tsc-watch --noClear -p ./calc --onSuccess \"node ./dist/app.js\"",
    "test": "jest --verbose --silent",
    "test:coverage": "jest --coverage --verbose --silent",
    "test:watch": "pnpm run test -- --watch"
  },
  "dependencies": {
    "@jest/globals": "^30.3.0"
  }
}